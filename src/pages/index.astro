---
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Just Beyond The Bend LLC — independent ventures, intentionally built." />
    <title>Just Beyond The Bend</title>
  </head>
  <body style="background-color: #FAFAF8; color: #1A1A1A; font-family: 'Trebuchet MS', Trebuchet, sans-serif; margin: 0;">

    <!-- Header -->
    <header style="position: sticky; top: 0; background-color: #FAFAF8; border-bottom: 1px solid #E8E8E4; z-index: 10; padding: 1rem 2rem;">
      <span style="font-size: 0.95rem; font-weight: 600; letter-spacing: 0.02em; color: #1A1A1A;">
        Just Beyond The Bend
      </span>
    </header>

    <main>

      <!-- Hero -->
      <section style="max-width: 52rem; margin: 0 auto; padding: 7rem 2rem 6rem;">
        <div style="display: inline-block; background-color: #F5C842; color: #1A1A1A; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; padding: 0.3rem 0.75rem; border-radius: 999px; margin-bottom: 2rem;">
          LLC
        </div>
        <h1 style="font-size: clamp(2.5rem, 6vw, 4.5rem); font-weight: 800; line-height: 1.05; letter-spacing: -0.03em; color: #1A1A1A; margin: 0 0 1.5rem;">
          Building,<br/>
          <span style="color: #6B3FA0;">for good.</span>
        </h1>
        <p style="font-size: 1.2rem; line-height: 1.65; color: #555; max-width: 36rem; margin: 0;">
          Just Beyond The Bend LLC — independent ventures, intentionally built.
        </p>
      </section>

      <!-- Ventures -->
      <section style="max-width: 52rem; margin: 0 auto; padding: 2rem 2rem 7rem;">
        <h2 style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #888; margin: 0 0 2rem;">
          Ventures
        </h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.25rem;">

          <!-- GoodReading.co card -->
          <a href="https://goodreading.co" target="_blank" rel="noopener noreferrer"
             style="display: block; background-color: #EDE4F7; border: 2px solid #D4C0EE; border-radius: 1rem; padding: 2rem; text-decoration: none;">
            <div style="font-size: 1.5rem; margin-bottom: 1rem;">📖</div>
            <h3 style="font-size: 1.1rem; font-weight: 700; color: #1A1A1A; margin: 0 0 0.5rem;">GoodReading.co</h3>
            <p style="font-size: 0.95rem; line-height: 1.55; color: #555; margin: 0 0 1.25rem;">
              A gamified reading curriculum for early readers.
            </p>
            <span style="font-size: 0.8rem; font-weight: 600; color: #6B3FA0; letter-spacing: 0.02em;">
              goodreading.co →
            </span>
          </a>

          <!-- Placeholder card -->
          <div style="background-color: #F3F3F0; border: 2px dashed #D8D8D2; border-radius: 1rem; padding: 2rem; display: flex; flex-direction: column; justify-content: center;">
            <div style="font-size: 1.5rem; margin-bottom: 1rem;">✦</div>
            <h3 style="font-size: 1.1rem; font-weight: 700; color: #AAA; margin: 0 0 0.5rem;">More coming soon</h3>
            <p style="font-size: 0.95rem; line-height: 1.55; color: #BBB; margin: 0;">
              The next venture is just beyond the bend.
            </p>
          </div>

        </div>
      </section>

      <!-- Divider -->
      <div style="max-width: 52rem; margin: 0 auto; padding: 0 2rem;">
        <hr style="border: none; border-top: 1px solid #E8E8E4;" />
      </div>

      <!-- Contact -->
      <section style="max-width: 52rem; margin: 0 auto; padding: 4rem 2rem 5rem; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1.5rem;">
        <p style="font-size: 1rem; color: #555; margin: 0;">Have a question or just want to say hi?</p>
        <a href="mailto:justbeyondthebend@gmail.com"
           style="display: inline-flex; align-items: center; gap: 0.5rem; background-color: #F5C842; color: #1A1A1A; font-weight: 700; font-size: 0.95rem; padding: 0.7rem 1.4rem; border-radius: 999px; text-decoration: none; letter-spacing: 0.01em;">
          Get in touch →
        </a>
      </section>

    </main>

    <!-- Footer -->
    <footer style="border-top: 1px solid #E8E8E4; padding: 1.5rem 2rem; text-align: center;">
      <span style="font-size: 0.8rem; color: #AAA;">© 2026 Just Beyond The Bend LLC</span>
    </footer>

  </body>
</html>
